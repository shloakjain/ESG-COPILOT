# Copy this file to .streamlit/secrets.toml for local development,
# OR paste its contents into the "Secrets" box in Streamlit Community Cloud
# (App settings -> Secrets) when deploying.
#
# NEVER commit your real secrets.toml to GitHub.

OPENAI_API_KEY = "sk-your-openai-api-key-here"

# Optional: override the default model
OPENAI_MODEL = "gpt-4o-mini"
